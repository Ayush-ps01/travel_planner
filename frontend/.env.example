# AtlasMind Environment Variables
# Copy this file to .env and fill in your keys

# Required: Anthropic API key (get from https://console.anthropic.com)
REACT_APP_ANTHROPIC_KEY=your_anthropic_api_key_here

# Optional: Google Maps API key (not used — app uses google.com/?q= links instead)
# REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_key_here
